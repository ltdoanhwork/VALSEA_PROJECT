# ── Required ──────────────────────────────────────────────────────────
VALSEA_API_KEY=your_valsea_api_key_here
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
BEDROCK_REGION=us-east-1

# ── Optional ──────────────────────────────────────────────────────────
# PORT=3000                          # Host port for the web app (default: 3000)
# BEDROCK_MODEL=                     # Override default Bedrock model
# USE_MOCK_QUIZ=false                # Use mock quiz data (for testing)
# USE_MOCK_FLASHCARDS=false          # Use mock flashcard data (for testing)
